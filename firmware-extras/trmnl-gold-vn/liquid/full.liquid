<!--
  TRMNL — Vàng DOJI Việt Nam (RLCD 1-bit)

  Source: https://giavang.doji.vn/api/prices  (XML, no Cloudflare)
  Poll every 30 min. Response is text/xml; Terminus stores it raw in
  `source_1.body`. We string-parse XML via Liquid `split` filter since
  stock Liquid has no XML parser.

  DOJI XML layout (excerpt):
    <GoldList>
      <DGPlist>
        <DateTime>...</DateTime>
        <Row Name='DOJI HN lẻ' Sell='151,400' Buy='148,400' />   (nghìn₫/lượng)
        <Row Name='DOJI HCM lẻ' Sell='15,140'  Buy='14,840' />   (nghìn₫/chỉ)
        ...
      </DGPlist>
      <IGPList><DateTime>...</DateTime> <Row Name='USD/VND' .../></IGPList>
      <JewelryList>
        <Row Name='Vàng 24k (nghìn/chỉ)' Sell='14,600' Buy='14,100' />
        <Row Name='Giá Nguyên Liệu 18K'  Sell='-'      Buy='10,095' />
        <Row Name='Giá Nguyên Liệu 14K'  Sell='-'      Buy='7,656'  />
        <Row Name='Nhẫn Tròn 9999 Hưng Thịnh Vượng' Sell='15,140' Buy='14,840' />
        ...
      </JewelryList>
    </GoldList>

  Layout (400x300):
    Header:   GIÁ VÀNG DOJI · <IGPList DateTime>
    Column:   LOẠI · MUA · BÁN
    6 rows (all nghìn₫/chỉ):
      1. Vàng miếng SJC · HCM lẻ
      2. Vàng miếng SJC · HCM buôn
      3. Nhẫn 9999 Hưng Thịnh Vượng
      4. Vàng 24K nữ trang
      5. Nguyên liệu 18K
      6. Nguyên liệu 14K
    Footer:   Đơn vị 1000₫/chỉ · giavang.doji.vn
-->
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    width: 400px; height: 300px; background: #fff; color: #000;
    font-family: Helvetica, Arial, sans-serif;
    -webkit-font-smoothing: none;
    text-rendering: geometricPrecision;
    font-weight: 700;
  }
  .card { width: 400px; height: 300px; padding: 0; overflow: hidden; }

  .hdr {
    display: flex; align-items: baseline; justify-content: space-between;
    padding: 6px 10px 4px;
    border-bottom: 2px solid #000;
  }
  .hdr .t { font-size: 20px; letter-spacing: 1px; }
  .hdr .d { font-family: Menlo, "Courier New", monospace; font-size: 15px; }

  table { width: 100%; border-collapse: collapse; table-layout: fixed; }
  thead th {
    font-size: 13px; letter-spacing: 1px;
    text-transform: uppercase;
    padding: 5px 8px 4px;
    border-bottom: 1px solid #000;
    text-align: right;
  }
  thead th.l { text-align: left; }
  tbody td {
    font-size: 17px;
    padding: 5px 8px;
    border-bottom: 1px solid #000;
    text-align: right;
    font-family: Menlo, "Courier New", monospace;
    line-height: 1.1;
  }
  tbody td.l {
    text-align: left;
    font-family: Helvetica, Arial, sans-serif;
    letter-spacing: 0.4px;
    font-size: 16px;
  }
  tbody tr:last-child td { border-bottom: none; }

  .foot {
    display: flex; align-items: center; justify-content: space-between;
    padding: 4px 10px 5px;
    border-top: 2px solid #000;
    font-size: 12px; letter-spacing: 0.8px;
    text-transform: uppercase;
  }
  .foot .r { font-family: Menlo, "Courier New", monospace; }
</style>

{%- comment -%}
  Grab raw XML body. Terminus stores response text at source_1.body when
  content-type is not JSON.
{%- endcomment -%}
{% assign body = source_1.body %}

{%- comment -%}
  Isolate the two XML blocks. This is important because DOJI reuses the
  same Name (e.g. "DOJI HCM lẻ") in BOTH DGPlist (unit: nghìn₫/chỉ)
  and JewelryList (unit: nghìn₫/lượng). We want everything in nghìn₫/chỉ,
  so we always pull miếng rows from DGPlist and nhẫn/24K/18K/14K from
  JewelryList.
{%- endcomment -%}
{% assign dgp = body | split: "<DGPlist>" | last | split: "</DGPlist>" | first %}
{% assign jl  = body | split: "<JewelryList>" | last | split: "</JewelryList>" | first %}

{%- comment -%}
  Extract IGPList DateTime (the freshest timestamp DOJI publishes).
  Structure: <IGPList><DateTime>17:16 05/07/2026</DateTime>...
{%- endcomment -%}
{% assign igp = body | split: "<IGPList>" | last | split: "</DateTime>" | first %}
{% assign ts = igp | split: "<DateTime>" | last | strip %}

{%- comment -%}
  Row extractor pattern (all rows below are nghìn₫/chỉ):
    * DGPlist:      DOJI HCM lẻ / DOJI HCM buôn
    * JewelryList:  Nhẫn Tròn 9999 Hưng Thịnh Vượng /
                    Vàng 24k (nghìn/chỉ) / Nguyên liệu 18K / Nguyên liệu 14K
{%- endcomment -%}

{% assign _r1 = dgp | split: "Name='DOJI HCM lẻ'" | last | split: "/>" | first %}
{% assign r1_sell = _r1 | split: "Sell='" | last | split: "'" | first %}
{% assign r1_buy  = _r1 | split: "Buy='"  | last | split: "'" | first %}

{% assign _r2 = dgp | split: "Name='DOJI HCM buôn'" | last | split: "/>" | first %}
{% assign r2_sell = _r2 | split: "Sell='" | last | split: "'" | first %}
{% assign r2_buy  = _r2 | split: "Buy='"  | last | split: "'" | first %}

{% assign _r3 = jl | split: "Name='Nhẫn Tròn 9999 Hưng Thịnh Vượng'" | last | split: "/>" | first %}
{% assign r3_sell = _r3 | split: "Sell='" | last | split: "'" | first %}
{% assign r3_buy  = _r3 | split: "Buy='"  | last | split: "'" | first %}

{% assign _r4 = jl | split: "Name='Vàng 24k (nghìn/chỉ)'" | last | split: "/>" | first %}
{% assign r4_sell = _r4 | split: "Sell='" | last | split: "'" | first %}
{% assign r4_buy  = _r4 | split: "Buy='"  | last | split: "'" | first %}

{% assign _r5 = jl | split: "Name='Giá Nguyên Liệu 18K'" | last | split: "/>" | first %}
{% assign r5_sell = _r5 | split: "Sell='" | last | split: "'" | first %}
{% assign r5_buy  = _r5 | split: "Buy='"  | last | split: "'" | first %}

{% assign _r6 = jl | split: "Name='Giá Nguyên Liệu 14K'" | last | split: "/>" | first %}
{% assign r6_sell = _r6 | split: "Sell='" | last | split: "'" | first %}
{% assign r6_buy  = _r6 | split: "Buy='"  | last | split: "'" | first %}

<div class="card">
  <div class="hdr">
    <div class="t">GIÁ VÀNG DOJI</div>
    <div class="d">{{ ts }}</div>
  </div>

  <table>
    <thead>
      <tr>
        <th class="l" style="width: 44%;">LOẠI</th>
        <th style="width: 26%;">MUA</th>
        <th style="width: 26%;">BÁN</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="l">SJC 1L · HCM LẺ</td>
        <td>{{ r1_buy }}</td>
        <td>{{ r1_sell }}</td>
      </tr>
      <tr>
        <td class="l">SJC 1L · HCM BUÔN</td>
        <td>{{ r2_buy }}</td>
        <td>{{ r2_sell }}</td>
      </tr>
      <tr>
        <td class="l">NHẪN 9999 · HTV</td>
        <td>{{ r3_buy }}</td>
        <td>{{ r3_sell }}</td>
      </tr>
      <tr>
        <td class="l">VÀNG 24K</td>
        <td>{{ r4_buy }}</td>
        <td>{{ r4_sell }}</td>
      </tr>
      <tr>
        <td class="l">NGUYÊN LIỆU 18K</td>
        <td>{{ r5_buy }}</td>
        <td>{{ r5_sell }}</td>
      </tr>
      <tr>
        <td class="l">NGUYÊN LIỆU 14K</td>
        <td>{{ r6_buy }}</td>
        <td>{{ r6_sell }}</td>
      </tr>
    </tbody>
  </table>

  <div class="foot">
    <div class="l">Đơn vị: 1000₫/chỉ</div>
    <div class="r">GIAVANG.DOJI.VN</div>
  </div>
</div>
