<!--
  TRMNL — Vàng DOJI Việt Nam (RLCD 1-bit)

  Source: https://giavang.doji.vn/api/prices  (XML, no Cloudflare)
  Poll every 30 min.

  ⚠ IMPORTANT: Terminus auto-parses XML into JSON. Structure:
    source_1.GoldList.DGPlist.Row       -> Array<{@Name,@Buy,@Sell,@Key}>
    source_1.GoldList.JewelryList.Row   -> Array<{@Name,@Buy,@Sell,@Key}>
    source_1.GoldList.IGPList.DateTime  -> "17:16 05/07/2026"
    source_1.GoldList.IGPList.Row       -> Hash (single obj) USD/VND

  Attributes use "@" prefix (XML→JSON convention). Access in Liquid:
    row["@Buy"]  or  compare row["@Name"] == "..."

  DGPlist HCM rows are in nghìn₫/chỉ.
  JewelryList HCM rows are in nghìn₫/lượng (same name, DIFFERENT unit!).
  We always pull HCM rows from DGPlist to keep everything in chỉ.

  6 rows (all nghìn₫/chỉ):
    1. Vàng miếng SJC · HCM lẻ    (DGPlist)
    2. Vàng miếng SJC · HCM buôn  (DGPlist)
    3. Nhẫn 9999 Hưng Thịnh Vượng (JewelryList @Key=nhanhung1chi)
    4. Vàng 24K nữ trang          (JewelryList @Key=vang24k)
    5. Nguyên liệu 18K            (JewelryList @Key=vang18k)
    6. Nguyên liệu 14K            (JewelryList @Key=vang14k)
-->
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    width: 400px; height: 300px; background: #fff; color: #000;
    font-family: Helvetica, Arial, sans-serif;
    -webkit-font-smoothing: none;
    text-rendering: geometricPrecision;
    font-weight: 700;
  }
  .card { width: 400px; height: 300px; padding: 0; overflow: hidden; }

  .hdr {
    display: flex; align-items: baseline; justify-content: space-between;
    padding: 6px 10px 4px;
    border-bottom: 2px solid #000;
  }
  .hdr .t { font-size: 20px; letter-spacing: 1px; }
  .hdr .d { font-family: Menlo, "Courier New", monospace; font-size: 15px; }

  table { width: 100%; border-collapse: collapse; table-layout: fixed; }
  thead th {
    font-size: 13px; letter-spacing: 1px;
    text-transform: uppercase;
    padding: 5px 8px 4px;
    border-bottom: 1px solid #000;
    text-align: right;
  }
  thead th.l { text-align: left; }
  tbody td {
    font-size: 17px;
    padding: 5px 8px;
    border-bottom: 1px solid #000;
    text-align: right;
    font-family: Menlo, "Courier New", monospace;
    line-height: 1.1;
  }
  tbody td.l {
    text-align: left;
    font-family: Helvetica, Arial, sans-serif;
    letter-spacing: 0.4px;
    font-size: 16px;
  }
  tbody tr:last-child td { border-bottom: none; }

  .foot {
    display: flex; align-items: center; justify-content: space-between;
    padding: 4px 10px 5px;
    border-top: 2px solid #000;
    font-size: 12px; letter-spacing: 0.8px;
    text-transform: uppercase;
  }
  .foot .r { font-family: Menlo, "Courier New", monospace; }
</style>

{%- comment -%}
  Init all row values to "-" so missing data renders cleanly.
{%- endcomment -%}
{% assign r1_buy = "-" %}{% assign r1_sell = "-" %}
{% assign r2_buy = "-" %}{% assign r2_sell = "-" %}
{% assign r3_buy = "-" %}{% assign r3_sell = "-" %}
{% assign r4_buy = "-" %}{% assign r4_sell = "-" %}
{% assign r5_buy = "-" %}{% assign r5_sell = "-" %}
{% assign r6_buy = "-" %}{% assign r6_sell = "-" %}

{%- comment -%}
  Scan DGPlist for miếng HCM lẻ / HCM buôn (nghìn₫/chỉ).
{%- endcomment -%}
{% for r in source_1.GoldList.DGPlist.Row %}
  {% if r["@Name"] == "DOJI HCM lẻ" %}
    {% assign r1_buy = r["@Buy"] %}
    {% assign r1_sell = r["@Sell"] %}
  {% elsif r["@Name"] == "DOJI HCM buôn" %}
    {% assign r2_buy = r["@Buy"] %}
    {% assign r2_sell = r["@Sell"] %}
  {% endif %}
{% endfor %}

{%- comment -%}
  Scan JewelryList for nhẫn 9999 / 24k / 18k / 14k by stable @Key.
  Using @Key (ASCII) is safer than @Name (Vietnamese diacritics).
{%- endcomment -%}
{% for r in source_1.GoldList.JewelryList.Row %}
  {% if r["@Key"] == "nhanhung1chi" %}
    {% assign r3_buy = r["@Buy"] %}
    {% assign r3_sell = r["@Sell"] %}
  {% elsif r["@Key"] == "vang24k" %}
    {% assign r4_buy = r["@Buy"] %}
    {% assign r4_sell = r["@Sell"] %}
  {% elsif r["@Key"] == "vang18k" %}
    {% assign r5_buy = r["@Buy"] %}
    {% assign r5_sell = r["@Sell"] %}
  {% elsif r["@Key"] == "vang14k" %}
    {% assign r6_buy = r["@Buy"] %}
    {% assign r6_sell = r["@Sell"] %}
  {% endif %}
{% endfor %}

{% assign ts = source_1.GoldList.IGPList.DateTime | default: "" %}

<div class="card">
  <div class="hdr">
    <div class="t">GIÁ VÀNG DOJI</div>
    <div class="d">{{ ts }}</div>
  </div>

  <table>
    <thead>
      <tr>
        <th class="l" style="width: 44%;">LOẠI</th>
        <th style="width: 26%;">MUA</th>
        <th style="width: 26%;">BÁN</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="l">SJC 1L · HCM LẺ</td>
        <td>{{ r1_buy }}</td>
        <td>{{ r1_sell }}</td>
      </tr>
      <tr>
        <td class="l">SJC 1L · HCM BUÔN</td>
        <td>{{ r2_buy }}</td>
        <td>{{ r2_sell }}</td>
      </tr>
      <tr>
        <td class="l">NHẪN 9999 · HTV</td>
        <td>{{ r3_buy }}</td>
        <td>{{ r3_sell }}</td>
      </tr>
      <tr>
        <td class="l">VÀNG 24K</td>
        <td>{{ r4_buy }}</td>
        <td>{{ r4_sell }}</td>
      </tr>
      <tr>
        <td class="l">NGUYÊN LIỆU 18K</td>
        <td>{{ r5_buy }}</td>
        <td>{{ r5_sell }}</td>
      </tr>
      <tr>
        <td class="l">NGUYÊN LIỆU 14K</td>
        <td>{{ r6_buy }}</td>
        <td>{{ r6_sell }}</td>
      </tr>
    </tbody>
  </table>

  <div class="foot">
    <div class="l">Đơn vị: 1000₫/chỉ</div>
    <div class="r">GIAVANG.DOJI.VN</div>
  </div>
</div>
