{%- comment -%}
  VN Stock Dashboard — 400x300 mono 1-bit (Waveshare ESP32-S3-RLCD-4.2)
  Data: SSI iBoard (10 sources)
    source_1  = VNINDEX
    source_2..7 = 6 user-configurable tickers (defaults: VNM,FPT,MSN,VIC,VHM,HPG)
    source_10 = VN30
  (source_8/source_9 still polled by settings.yml as t7/t8 to preserve
  polling URL indices — silently ignored in this template because 8 rows
  fight the RLCD's 15px readability floor. Edit polling_url in settings.yml
  to trim to 8 URLs if you want to save 2 API calls per poll.)
{%- endcomment -%}

{%- assign idx_bars   = source_1.data  -%}
{%- assign idx_n      = idx_bars.c | size -%}
{%- assign idx_last   = idx_bars.c | last -%}
{%- assign idx_prev_i = idx_n | minus: 2 -%}
{%- assign idx_prev   = idx_bars.c[idx_prev_i] -%}
{%- assign idx_chg    = idx_last | minus: idx_prev -%}
{%- assign idx_pct    = idx_chg | times: 10000 | divided_by: idx_prev | divided_by: 100.0 -%}
{%- if idx_chg > 0 -%}{% assign idx_arrow = "▲" %}{% assign idx_sign = "+" %}
{%- elsif idx_chg < 0 -%}{% assign idx_arrow = "▼" %}{% assign idx_sign = "" %}
{%- else -%}{% assign idx_arrow = "=" %}{% assign idx_sign = "" %}{%- endif -%}

{%- assign vn30_bars = source_10.data -%}
{%- assign vn30_n    = vn30_bars.c | size -%}
{%- assign vn30_last = vn30_bars.c | last -%}
{%- assign vn30_prev_i = vn30_n | minus: 2 -%}
{%- assign vn30_prev = vn30_bars.c[vn30_prev_i] -%}
{%- assign vn30_chg  = vn30_last | minus: vn30_prev -%}
{%- assign vn30_pct  = vn30_chg | times: 10000 | divided_by: vn30_prev | divided_by: 100.0 -%}
{%- if vn30_chg > 0 -%}{% assign vn30_sign = "+" %}{%- else -%}{% assign vn30_sign = "" %}{%- endif -%}

<div style="width:400px;height:300px;background:#fff;color:#000;
            font-family:'Helvetica Neue','Helvetica','Arial',sans-serif;
            -webkit-font-smoothing:none;text-rendering:geometricPrecision;
            padding:8px 10px;box-sizing:border-box;
            display:flex;flex-direction:column;">

  <div style="display:flex;justify-content:space-between;align-items:baseline;
              border-bottom:3px solid #000;padding-bottom:4px;margin-bottom:4px;">
    <div style="font-size:20px;font-weight:900;letter-spacing:1px;">VN STOCK</div>
    {%- assign now_vn = "now" | date: "%s" | plus: 25200 -%}
    <div style="font-size:13px;font-weight:700;">{{ now_vn | date: "%d/%m %H:%M" }}</div>
  </div>

  <div style="display:flex;justify-content:space-between;align-items:baseline;padding:2px 2px 4px 2px;">
    <div style="font-size:14px;font-weight:900;letter-spacing:1px;">VN-INDEX</div>
    <div style="font-size:22px;font-weight:900;font-family:'Menlo','Courier New',monospace;">{{ idx_last }}</div>
    <div style="font-size:13px;font-weight:700;font-family:'Menlo','Courier New',monospace;">{{ idx_arrow }}{{ idx_sign }}{{ idx_pct | round: 2 }}%</div>
  </div>
  <div style="height:2px;background:#000;margin-bottom:2px;"></div>

  <table style="width:100%;border-collapse:collapse;font-weight:700;">
    {%- for i in (2..7) -%}
      {%- case i -%}
        {%- when 2 -%}{%- assign s = source_2 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t1 | default: "VNM" -%}
        {%- when 3 -%}{%- assign s = source_3 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t2 | default: "FPT" -%}
        {%- when 4 -%}{%- assign s = source_4 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t3 | default: "MSN" -%}
        {%- when 5 -%}{%- assign s = source_5 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t4 | default: "VIC" -%}
        {%- when 6 -%}{%- assign s = source_6 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t5 | default: "VHM" -%}
        {%- when 7 -%}{%- assign s = source_7 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t6 | default: "HPG" -%}
      {%- endcase -%}

      {%- assign bars = s.data -%}
      {%- assign n    = bars.c | size -%}
      {%- if n > 1 -%}
        {%- assign last = bars.c | last -%}
        {%- assign prev_i = n | minus: 2 -%}
        {%- assign prev = bars.c[prev_i] -%}
        {%- assign chg  = last | minus: prev -%}
        {%- assign pct  = chg | times: 10000 | divided_by: prev | divided_by: 100.0 -%}
        {%- if chg > 0 -%}{% assign ar = "▲" %}{% assign sg = "+" %}
        {%- elsif chg < 0 -%}{% assign ar = "▼" %}{% assign sg = "" %}
        {%- else -%}{% assign ar = "=" %}{% assign sg = "" %}{%- endif -%}
        <tr style="border-bottom:1px solid #000;">
          <td style="padding:5px 3px;font-size:16px;font-weight:900;letter-spacing:1px;">{{ label }}</td>
          <td style="padding:5px 3px;font-size:16px;font-weight:700;text-align:right;font-family:'Menlo','Courier New',monospace;">{{ last }}</td>
          <td style="padding:5px 3px;font-size:16px;font-weight:900;text-align:center;width:16px;">{{ ar }}</td>
          <td style="padding:5px 3px;font-size:16px;font-weight:900;text-align:right;font-family:'Menlo','Courier New',monospace;">{{ sg }}{{ pct | round: 2 }}%</td>
        </tr>
      {%- else -%}
        <tr style="border-bottom:1px solid #000;">
          <td style="padding:5px 3px;font-size:16px;font-weight:900;">{{ label }}</td>
          <td colspan="3" style="padding:5px 3px;font-size:14px;text-align:right;">no data</td>
        </tr>
      {%- endif -%}
    {%- endfor -%}
  </table>

  <div style="margin-top:auto;padding-top:4px;border-top:2px solid #000;
              display:flex;justify-content:space-between;font-size:12px;font-weight:700;">
    <span style="font-family:'Menlo','Courier New',monospace;">VN30 {{ vn30_last }} {{ vn30_sign }}{{ vn30_pct | round: 2 }}%</span>
    <span style="letter-spacing:1px;">SSI IBOARD</span>
  </div>

</div>
