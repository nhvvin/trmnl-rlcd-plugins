{%- comment -%}
  VN Stock Dashboard — 400x300 mono e-ink
  Data: SSI iBoard (10 sources)
    source_1  = VNINDEX
    source_2..9 = 8 user-configurable tickers (defaults: VNM,FPT,MSN,VIC,VHM,HPG,VCB,MWG)
    source_10 = VN30
{%- endcomment -%}

{%- comment -%} ---- helper: extract latest close + previous close from SSI bars ----
  SSI iBoard trả về EITHER shape phẳng {t,c,o,h,l,v} HOẶC shape bọc
  {code, message, data:{t,c,o,h,l,v}}. Terminus lưu raw response body vào
  source_N.data, nên ta thử wrapped path trước rồi fallback về flat.
{%- endcomment -%}
{%- assign idx_bars   = source_1.data.data | default: source_1.data -%}
{%- assign idx_n      = idx_bars.c | size -%}
{%- assign idx_last   = idx_bars.c | last -%}
{%- assign idx_prev_i = idx_n | minus: 2 -%}
{%- assign idx_prev   = idx_bars.c[idx_prev_i] -%}
{%- assign idx_chg    = idx_last | minus: idx_prev -%}
{%- assign idx_pct    = idx_chg | times: 10000 | divided_by: idx_prev | divided_by: 100.0 -%}
{%- if idx_chg > 0 -%}{% assign idx_arrow = "▲" %}{% assign idx_sign = "+" %}
{%- elsif idx_chg < 0 -%}{% assign idx_arrow = "▼" %}{% assign idx_sign = "" %}
{%- else -%}{% assign idx_arrow = "=" %}{% assign idx_sign = "" %}{%- endif -%}

{%- assign vn30_bars = source_10.data.data | default: source_10.data -%}
{%- assign vn30_n    = vn30_bars.c | size -%}
{%- assign vn30_last = vn30_bars.c | last -%}
{%- assign vn30_prev_i = vn30_n | minus: 2 -%}
{%- assign vn30_prev = vn30_bars.c[vn30_prev_i] -%}
{%- assign vn30_chg  = vn30_last | minus: vn30_prev -%}
{%- assign vn30_pct  = vn30_chg | times: 10000 | divided_by: vn30_prev | divided_by: 100.0 -%}
{%- if vn30_chg > 0 -%}{% assign vn30_arrow = "▲" %}{% assign vn30_sign = "+" %}
{%- elsif vn30_chg < 0 -%}{% assign vn30_arrow = "▼" %}{% assign vn30_sign = "" %}
{%- else -%}{% assign vn30_arrow = "=" %}{% assign vn30_sign = "" %}{%- endif -%}

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { width: 400px; height: 300px; background: #fff; color: #000;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; -webkit-font-smoothing: none; }
  .frame { width: 400px; height: 300px; padding: 4px 12px; display: flex; flex-direction: column; }
  .header { display: flex; justify-content: space-between; align-items: baseline; height: 20px; }
  .header .title { font-size: 14px; font-weight: 800; letter-spacing: 1px; }
  .header .time  { font-size: 11px; font-weight: 500; }
  .rule { height: 2px; background: #000; margin: 1px 0; }
  .rule-thin { height: 1px; background: #000; margin: 1px 0; }
  .idx { display: flex; justify-content: space-between; align-items: baseline;
    height: 26px; padding: 2px 4px; }
  .idx .name  { font-size: 12px; font-weight: 700; letter-spacing: 0.5px; }
  .idx .price { font-size: 18px; font-weight: 800; font-variant-numeric: tabular-nums; }
  .idx .delta { font-size: 12px; font-weight: 700; font-variant-numeric: tabular-nums; }
  table.tickers { width: 100%; font-size: 12px; font-variant-numeric: tabular-nums;
    border-collapse: collapse; }
  table.tickers td { height: 22px; line-height: 22px; padding: 0; vertical-align: middle; }
  .t-code   { width: 50px; font-weight: 700; }
  .t-price  { width: 90px; text-align: right; padding-right: 4px; font-weight: 600; }
  .t-arrow  { width: 16px; text-align: center; font-weight: 700; }
  .t-pct    { width: 70px; text-align: right; padding-right: 8px; font-weight: 600; }
  .t-vol    { text-align: right; opacity: 0.75; }
  .footer { display: flex; justify-content: space-between; align-items: baseline;
    height: 16px; font-size: 10px; opacity: 0.75; }
  .footer .vn30  { font-weight: 700; font-variant-numeric: tabular-nums; opacity: 1; }
  .footer .brand { letter-spacing: 1px; }
  .neg { } .pos { } .flat { }
</style>

<div class="frame">

  <!-- ── Header ─────────────────────────── -->
  <div class="header">
    <div class="title">VN STOCK</div>
    {%- comment -%} VN timezone fixed UTC+7 (25200s) {%- endcomment -%}
    {%- assign now_vn = "now" | date: "%s" | plus: 25200 -%}
    <div class="time">{{ now_vn | date: "%d/%m  %H:%M" }}</div>
  </div>
  <div class="rule"></div>

  <!-- ── VN-INDEX hero ──────────────────── -->
  <div class="idx">
    <div class="name">VN-INDEX</div>
    <div class="price">{{ idx_last }}</div>
    <div class="delta">{{ idx_arrow }} {{ idx_sign }}{{ idx_chg | round: 2 }} ({{ idx_sign }}{{ idx_pct | round: 2 }}%)</div>
  </div>
  <div class="rule-thin"></div>

  <!-- ── 8 ticker rows ──────────────────── -->
  <table class="tickers">
    {%- for i in (2..9) -%}
      {%- case i -%}
        {%- when 2 -%}{%- assign s = source_2 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t1 | default: "VNM" -%}
        {%- when 3 -%}{%- assign s = source_3 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t2 | default: "FPT" -%}
        {%- when 4 -%}{%- assign s = source_4 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t3 | default: "MSN" -%}
        {%- when 5 -%}{%- assign s = source_5 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t4 | default: "VIC" -%}
        {%- when 6 -%}{%- assign s = source_6 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t5 | default: "VHM" -%}
        {%- when 7 -%}{%- assign s = source_7 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t6 | default: "HPG" -%}
        {%- when 8 -%}{%- assign s = source_8 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t7 | default: "VCB" -%}
        {%- when 9 -%}{%- assign s = source_9 -%}{%- assign label = trmnl.plugin_settings.custom_fields_values.t8 | default: "MWG" -%}
      {%- endcase -%}

      {%- assign bars = s.data.data | default: s.data -%}
      {%- assign n    = bars.c | size -%}
      {%- if n > 1 -%}
        {%- assign last = bars.c | last -%}
        {%- assign prev_i = n | minus: 2 -%}
        {%- assign prev = bars.c[prev_i] -%}
        {%- assign chg  = last | minus: prev -%}
        {%- assign pct  = chg | times: 10000 | divided_by: prev | divided_by: 100.0 -%}
        {%- assign vol  = bars.v | last -%}
        {%- if vol >= 1000000 -%}
          {%- assign vol_m = vol | times: 1.0 | divided_by: 1000000 | round: 1 -%}
          {%- assign vol_disp = vol_m | append: "M" -%}
        {%- elsif vol >= 1000 -%}
          {%- assign vol_k = vol | divided_by: 1000 -%}
          {%- assign vol_disp = vol_k | append: "K" -%}
        {%- else -%}
          {%- assign vol_disp = vol -%}
        {%- endif -%}
        {%- if chg > 0 -%}{% assign ar = "▲" %}{% assign sg = "+" %}
        {%- elsif chg < 0 -%}{% assign ar = "▼" %}{% assign sg = "" %}
        {%- else -%}{% assign ar = "=" %}{% assign sg = "" %}{%- endif -%}
        <tr>
          <td class="t-code">{{ label }}</td>
          <td class="t-price">{{ last }}</td>
          <td class="t-arrow">{{ ar }}</td>
          <td class="t-pct">{{ sg }}{{ pct | round: 2 }}%</td>
          <td class="t-vol">{{ vol_disp }}</td>
        </tr>
      {%- else -%}
        <tr>
          <td class="t-code">{{ label }}</td>
          <td class="t-price">—</td>
          <td class="t-arrow"></td>
          <td class="t-pct">no data</td>
          <td class="t-vol"></td>
        </tr>
      {%- endif -%}
    {%- endfor -%}
  </table>

  <!-- ── Footer ─────────────────────────── -->
  <div class="rule-thin"></div>
  <div class="footer">
    <span class="vn30">VN30 {{ vn30_last }} {{ vn30_arrow }} {{ vn30_sign }}{{ vn30_pct | round: 2 }}%</span>
    <span class="brand">SSI iBoard</span>
  </div>

</div>
