{%- assign currencies_str = trmnl.plugin_settings.custom_fields_values.currencies | default: "EUR,GBP,JPY,CAD,AUD,CNY" -%}
{%- assign symbols = currencies_str | split: "," -%}
{%- assign date_count = 0 -%}
{%- for d in source_1.rates -%}
  {%- if date_count == 0 -%}
    {%- assign first_rates = d[1] -%}
  {%- endif -%}
  {%- assign last_date = d[0] -%}
  {%- assign last_rates = d[1] -%}
  {%- assign date_count = date_count | plus: 1 -%}
{%- endfor -%}
<div style="width:400px;height:300px;background:#fff;color:#000;
            font-family:'Helvetica Neue','Helvetica','Arial',sans-serif;
            -webkit-font-smoothing:none;text-rendering:geometricPrecision;
            padding:10px;box-sizing:border-box;
            display:flex;flex-direction:column;">

  <div style="display:flex;justify-content:space-between;align-items:baseline;
              border-bottom:3px solid #000;padding-bottom:5px;margin-bottom:5px;">
    <div style="font-size:22px;font-weight:900;letter-spacing:1px;">{{ source_1.base }} INDEX</div>
    <div style="font-size:14px;font-weight:700;">{{ date_count }}D · {{ last_date }}</div>
  </div>

  <table style="width:100%;border-collapse:collapse;font-weight:700;">
    <thead>
      <tr style="border-bottom:2px solid #000;">
        <th style="text-align:left;padding:5px 4px;font-size:15px;font-weight:900;letter-spacing:1px;">SYM</th>
        <th style="text-align:right;padding:5px 4px;font-size:15px;font-weight:900;letter-spacing:1px;">NOW</th>
        <th style="text-align:right;padding:5px 4px;font-size:15px;font-weight:900;letter-spacing:1px;">Δ%</th>
      </tr>
    </thead>
    <tbody>
      {%- for sym in symbols limit: 6 -%}
      {%- assign s = sym | strip | upcase -%}
      {%- assign fv = first_rates[s] | plus: 0.0 -%}
      {%- assign lv = last_rates[s]  | plus: 0.0 -%}
      {%- assign delta = lv | minus: fv -%}
      {%- assign pct = delta | times: 100.0 | divided_by: fv | round: 2 -%}
      <tr style="border-bottom:1px solid #000;">
        <td style="padding:7px 4px;font-size:18px;font-weight:900;letter-spacing:1px;">{{ s }}</td>
        <td style="padding:7px 4px;font-size:18px;font-weight:700;text-align:right;font-family:'Menlo','Courier New',monospace;">{{ lv | round: 4 }}</td>
        <td style="padding:7px 4px;font-size:18px;font-weight:900;text-align:right;font-family:'Menlo','Courier New',monospace;">{% if pct > 0 %}+{% endif %}{{ pct }}%</td>
      </tr>
      {%- endfor -%}
    </tbody>
  </table>

  <div style="margin-top:auto;padding-top:6px;border-top:2px solid #000;
              display:flex;justify-content:space-between;font-size:12px;font-weight:700;">
    <span>NGUỒN: FRANKFURTER · ECB</span>
    <span>{{ date_count }} DAY WINDOW</span>
  </div>

</div>
