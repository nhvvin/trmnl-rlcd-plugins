{%- assign currencies_str = trmnl.plugin_settings.custom_fields_values.currencies | default: "EUR,GBP,JPY,CAD,AUD,CNY" -%}
{%- assign symbols = currencies_str | split: "," -%}
{%- assign date_count = 0 -%}
{%- for d in source_1.rates -%}
  {%- if date_count == 0 -%}
    {%- assign first_date = d[0] -%}
    {%- assign first_rates = d[1] -%}
  {%- endif -%}
  {%- assign last_date = d[0] -%}
  {%- assign last_rates = d[1] -%}
  {%- assign date_count = date_count | plus: 1 -%}
{%- endfor -%}
<div class="screen" style="width:400px;height:300px;background:#fff;color:#000;font-family:'Inter','Helvetica',sans-serif;padding:8px;box-sizing:border-box;display:flex;flex-direction:column;gap:4px;">
  <div style="display:flex;justify-content:space-between;align-items:baseline;border-bottom:2px solid #000;padding-bottom:4px;">
    <div style="font-size:16px;font-weight:800;letter-spacing:1px;">{{ source_1.base }} INDEX</div>
    <div style="font-size:10px;">{{ first_date }} → {{ last_date }} · {{ date_count }}d</div>
  </div>
  <table style="width:100%;border-collapse:collapse;font-size:13px;">
    <thead>
      <tr style="border-bottom:1px solid #000;">
        <th style="text-align:left;padding:2px 4px;font-weight:700;">SYM</th>
        <th style="text-align:right;padding:2px 4px;font-weight:700;">NOW</th>
        <th style="text-align:right;padding:2px 4px;font-weight:700;">START</th>
        <th style="text-align:right;padding:2px 4px;font-weight:700;">Δ%</th>
      </tr>
    </thead>
    <tbody>
      {%- for sym in symbols -%}
      {%- assign s = sym | strip | upcase -%}
      {%- assign fv = first_rates[s] -%}
      {%- assign lv = last_rates[s] -%}
      {%- assign delta = lv | minus: fv -%}
      {%- assign pct = delta | times: 100.0 | divided_by: fv | round: 2 -%}
      <tr style="border-bottom:1px dotted #999;">
        <td style="padding:4px;font-weight:700;">{{ s }}</td>
        <td style="text-align:right;padding:4px;">{{ lv }}</td>
        <td style="text-align:right;padding:4px;color:#555;">{{ fv }}</td>
        <td style="text-align:right;padding:4px;font-weight:700;">{% if pct > 0 %}+{% endif %}{{ pct }}%</td>
      </tr>
      {%- endfor -%}
    </tbody>
  </table>
  <div style="margin-top:auto;border-top:1px solid #000;padding-top:3px;display:flex;justify-content:space-between;font-size:9px;color:#444;">
    <span>FRANKFURTER · ECB</span>
    <span>Currency Index</span>
  </div>
</div>
